{
  "description": "EU Hydro Hydro-DEM raster (Ireland)",
  "steps": [
    {
      "check_ident": "qc_tool.raster.unzip",
      "required": true
    },
    {
      "check_ident": "qc_tool.raster.naming",
      "required": true,
      "parameters": {
        "layer_names": {
          "raster": "^clms_euhydro_dem_(?P<aoi_code>[0-9a-zA-Z_]+)_v[0-9]{2}"
        },
        "aoi_codes": [
          "ie_nir"
        ],
        "epsg_codes": [
          "03035"
        ],
        "extensions": [
          ".tif"
        ],
        "reference_year": "2026"
      }
    },
    {
      "check_ident": "qc_tool.raster.epsg",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ],
        "epsg": 3035
      }
    },
    {
      "check_ident": "qc_tool.raster.pixel_size",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ],
        "pixelsize": 10
      }
    },
    {
      "check_ident": "qc_tool.raster.origin",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ]
      }
    },
    {
      "check_ident": "qc_tool.raster.bit_depth",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ],
        "datatype": "float32"
      }
    },
    {
      "check_ident": "qc_tool.raster.compress",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ],
        "compression": [
          "LZW", "DEFLATE"
        ]
      }
    },
    {
      "check_ident": "qc_tool.raster.tile",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ],
        "max_blocksize": 1024
      }
    },
    {
      "check_ident": "qc_tool.raster.cog",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ]
      }
    },
    {
      "check_ident": "qc_tool.raster.value_min_max",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ],
        "min_allowed": -400.0,
        "max_allowed": 8849.0
      }
    },
    {
      "check_ident": "qc_tool.raster.nodata",
      "required": false,
      "parameters": {
        "layers": [
          "raster"
        ],
        "nodata_value": -3.4028235e+38
      }
    }
  ]
}
